{
  "manifest_version": 3,
  "name": "Accessibility Enhancer",
  "version": "1.0.0",
  "description": "Improves website accessibility by adjusting text contrast and size",
  "permissions": [
    "activeTab",
    "storage",
    "tts"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["widget.html", "widget.css"],
      "matches": ["<all_urls>"]
    }
  ]
}

